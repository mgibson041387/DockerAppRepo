<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Maybe: Know your business, in plain English.</title>
        <link
            rel="icon"
            type="image/png"
            href="favicon-96x96.png"
            sizes="96x96"
        />
        <link rel="icon" type="image/svg+xml" href="favicon.svg" />
        <link rel="shortcut icon" href="favicon.ico" />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="apple-touch-icon.png"
        />
        <meta name="apple-mobile-web-app-title" content="Maybe" />
        <link rel="manifest" href="site.webmanifest" />
        <style>
            @import url("css/general-sans.css");
            @import url("css/inter.css");

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                /* background: linear-gradient(to top, #BFBBFD 0%, #D7FBFF 20%, #FFFFFF 40%); */
                font-family: "Inter", sans-serif;
                font-weight: 400;
                font-feature-settings:
                    "salt" on,
                    "ss02" on;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
                position: relative;
                cursor: crosshair;
                margin: 0;
                padding: 0;
            }

            .main-content {
                flex: 1;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 80px 0 40px; /* Top padding for header, bottom for content */
            }

            .container {
                width: 90%;
                max-width: 1400px;
                margin: 0 auto;
                padding: 40px;
                position: relative;
            }

            .text-wrapper {
                font-size: clamp(2rem, 5vw, 4rem);
                line-height: 1.1;
                position: relative;
                text-align: center;
                max-width: 90%;
                margin: 0 auto;
            }

            .blur-text {
                color: #d3d3d3;
                position: relative;
                display: block;
                font-family: GeneralSans-Semibold, sans-serif;
            }

            .blur-word {
                display: inline-block;
                position: relative;
            }

            .blur-text span {
                display: inline-block;
                transition:
                    filter 0.6s ease-out,
                    transform 0.6s ease-out;
            }

            .blur-text span.blurring {
                filter: blur(4px);
                transform: scale(0.98) translateY(1px);
            }

            .highlight-text {
                color: #000;
                margin-top: 0.5em;
                font-family: GeneralSans-Semibold, sans-serif;
            }

            .follow-text {
                margin-top: 2em;
                font-family: "Inter", sans-serif;
                font-weight: 400;
                font-feature-settings:
                    "salt" on,
                    "ss02" on;
                font-size: 1rem;
                color: #9e9e9e;
                text-align: center;
            }

            .follow-text a {
                color: #171717;
                text-decoration: none;
                transition: color 0.2s ease;
                font-family: "Inter", sans-serif;
                font-weight: 500;
                font-feature-settings:
                    "salt" on,
                    "ss02" on;
            }

            .follow-text a:hover {
                color: #000;
            }

            .header-logo {
                position: fixed;
                top: 40px;
                left: 50%;
                transform: translateX(-50%);
                display: flex;
                flex-direction: row;
                align-items: center;
                gap: 10px;
                z-index: 10;
            }

            .header-logo img {
                width: 120px;
                height: auto;
            }

            .relaunch-pill {
                background-color: #f5f5f5;
                padding: 4px 10px;
                border-radius: 6px;
                font-family: "Inter", sans-serif;
                font-weight: 500;
                font-feature-settings:
                    "salt" on,
                    "ss02" on;
                font-size: 11px;
                color: #999;
                text-transform: uppercase;
            }

            .footer {
                padding: 40px 20px 20px;
                text-align: center;
                font-family: "Inter", sans-serif;
                font-weight: 400;
                font-feature-settings:
                    "salt" on,
                    "ss02" on;
                font-size: 0.8rem;
                color: rgba(0, 0, 0, 0.5);
                max-width: 300px;
                margin: 0 auto;
            }

            .footer a {
                color: rgba(0, 0, 0, 0.7);
                text-decoration: underline;
                transition: color 0.2s ease;
            }

            .footer a:hover {
                color: rgba(0, 0, 0, 0.9);
            }

            .email-form-container {
                margin-top: 0.5em;
                text-align: center;
            }

            .email-form {
                display: flex;
                gap: 10px;
                justify-content: center;
                align-items: center;
                max-width: 500px;
                margin: 0 auto;
            }

            .email-input {
                flex: 1;
                padding: 12px 20px;
                font-family: "Inter", sans-serif;
                font-weight: 400;
                font-feature-settings:
                    "salt" on,
                    "ss02" on;
                font-size: 1rem;
                border-radius: 16px;
                border: 1px solid rgba(39, 39, 42, 0.1);
                background: #fff;
                box-shadow:
                    0 -1px 0 0 rgba(0, 0, 0, 0.1) inset,
                    0 1px 2px 0 rgba(0, 0, 0, 0.05);
                color: #171717;
                transition:
                    border-color 0.2s ease,
                    box-shadow 0.2s ease;
            }

            .email-input:focus {
                outline: none;
                border-color: rgba(39, 39, 42, 0.2);
                box-shadow:
                    0 -1px 0 0 rgba(0, 0, 0, 0.1) inset,
                    0 1px 2px 0 rgba(0, 0, 0, 0.05),
                    0 0 0 3px rgba(39, 39, 42, 0.05);
            }

            .email-input::placeholder {
                color: #9e9e9e;
            }

            .submit-button {
                padding: 12px 24px;
                font-family: "Inter", sans-serif;
                font-weight: 500;
                font-feature-settings:
                    "salt" on,
                    "ss02" on;
                font-size: 1rem;
                background: #171717;
                color: #fff;
                border: none;
                border-radius: 30px;
                cursor: pointer;
                transition:
                    background-color 0.2s ease,
                    transform 0.1s ease;
                white-space: nowrap;
            }

            .submit-button:hover {
                background: #000;
                transform: translateY(-1px);
            }

            .submit-button:active {
                transform: translateY(0);
            }

            .submit-button:disabled {
                background: #9e9e9e;
                cursor: not-allowed;
                transform: none;
            }

            .form-message {
                margin-top: 1em;
                font-family: "Inter", sans-serif;
                font-weight: 400;
                font-feature-settings:
                    "salt" on,
                    "ss02" on;
                font-size: 0.9rem;
                min-height: 1.2em;
            }

            .form-message.success {
                color: #22c55e;
            }

            .form-message.error {
                color: #ef4444;
            }

            .features-section {
                margin-top: 0.5em;
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 25px;
                max-width: 1000px;
                margin-left: auto;
                margin-right: auto;
                padding: 0 2em;
            }

            .feature-item {
                text-align: center;
                padding: 0;
            }

            .feature-icon {
                font-size: 2.5rem;
                margin-bottom: 0.5em;
                opacity: 0.8;
            }

            .feature-title {
                font-family: GeneralSans-Semibold, sans-serif;
                font-size: 1.1rem;
                color: #171717;
                margin-bottom: 0.5em;
                line-height: 1.3;
            }

            .feature-description {
                font-family: "Inter", sans-serif;
                font-weight: 400;
                font-feature-settings:
                    "salt" on,
                    "ss02" on;
                font-size: 0.9rem;
                color: #9e9e9e;
                line-height: 1.4;
            }

            @media (max-width: 768px) {
                .container {
                    padding: 20px;
                }

                .text-wrapper {
                    font-size: clamp(1.8rem, 7vw, 2.5rem);
                    max-width: 100%;
                }

                .follow-text {
                    font-size: 0.8rem;
                }

                .header-logo {
                    top: 20px;
                }

                .header-logo img {
                    width: 140px;
                }

                .relaunch-pill {
                    display: none;
                }

                .email-form {
                    flex-direction: column;
                    gap: 12px;
                }

                .email-input {
                    width: 100%;
                }

                .submit-button {
                    width: 100%;
                }

                .features-section {
                    grid-template-columns: 1fr;
                    gap: 1em;
                    margin-top: 2em;
                    padding: 0 1em;
                }

                .feature-icon {
                    font-size: 2rem;
                }

                .feature-title {
                    font-size: 1rem;
                }

                .feature-description {
                    font-size: 0.85rem;
                }
            }
        </style>
    </head>
    <body>
        <div class="header-logo">
            <img src="images/logo.svg" alt="Maybe Logo" />
            <div class="relaunch-pill">In Early Access Now</div>
        </div>

        <div class="main-content">
            <div class="container">
                <div class="text-wrapper">
                    <div class="blur-text" id="blurText">
                        No SQL. No spreadsheets. No formulas. No long setup. No learning curve. No four hour tutorials. No rows. No bloat. No analysts. No waiting.
                    </div>
                    <div class="highlight-text">
                        Your business, <br />in plain English.
                    </div>
                    <div class="email-form-container">
                        <a
                            href="https://app.maybe.co/registration/new"
                            class="submit-button"
                            style="display: inline-block; text-decoration: none"
                            >Start your free trial now</a
                        >
                        <div
                            style="
                                margin-top: 1em;
                                font-size: 0.9rem;
                                color: #9e9e9e;
                            "
                        >
                            Just $50/mo after your trial
                        </div>
                    </div>
                    <div class="features-section">
                        <div class="feature-item">
                            <div class="feature-icon">📊</div>
                            <div class="feature-title">Connect QuickBooks</div>
                            <div class="feature-description">
                                Seamlessly sync your financial data in seconds
                            </div>
                        </div>
                        <div class="feature-item">
                            <div class="feature-icon">🎯</div>
                            <div class="feature-title">
                                Play the what-if game
                            </div>
                            <div class="feature-description">
                                Model scenarios and see instant projections
                            </div>
                        </div>
                        <div class="feature-item">
                            <div class="feature-icon">✨</div>
                            <div class="feature-title">
                                No spreadsheets. Ever.
                            </div>
                            <div class="feature-description">
                                Get insights without formulas or pivot tables
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="footer">
            Looking for the personal finance version of Maybe?
            <a
                href="https://github.com/maybe-finance/maybe"
                target="_blank"
                rel="noopener noreferrer"
                >Find the repository here</a
            >.
            <div style="margin-top: 10px">
                <a href="privacy.html">Privacy</a> ·
                <a href="terms.html">Terms</a>
            </div>
        </div>

        <script>
            // Split text into sentences and words
            const blurText = document.getElementById("blurText");
            const text = blurText.textContent.trim();

            // Split into sentences first
            const sentences = text.split(/(?<=\.)\s+/);
            let sentenceSpans = [];

            blurText.innerHTML = sentences
                .map((sentence, sIndex) => {
                    const words = sentence.split(" ");
                    const sentenceHTML = words
                        .map(
                            (word, wIndex) =>
                                `<span data-sentence="${sIndex}" data-word="${wIndex}">${word}</span>`,
                        )
                        .join(" ");
                    return `<span class="sentence-group" data-sentence-index="${sIndex}">${sentenceHTML}</span> `;
                })
                .join("");

            // Get all word spans
            const spans = blurText.querySelectorAll("span[data-word]");
            const sentenceGroups = blurText.querySelectorAll(".sentence-group");
            let currentIndex = 0;
            let isHovering = false;
            let hoveredSentence = null;

            // Add hover listeners to detect when mouse is over text area
            blurText.addEventListener("mouseenter", () => {
                isHovering = true;
            });

            blurText.addEventListener("mouseleave", () => {
                isHovering = false;
                hoveredSentence = null;
            });

            // Add hover listeners to each sentence group
            sentenceGroups.forEach((group) => {
                group.addEventListener("mouseenter", (e) => {
                    hoveredSentence = parseInt(group.dataset.sentenceIndex);
                });

                group.addEventListener("mouseleave", () => {
                    hoveredSentence = null;
                });
            });

            function animateBlur() {
                if (isHovering && hoveredSentence !== null) {
                    // When hovering, blur everything except the hovered sentence
                    spans.forEach((span) => {
                        const sentenceIndex = parseInt(span.dataset.sentence);
                        if (sentenceIndex === hoveredSentence) {
                            span.style.filter = `blur(0px)`;
                        } else {
                            span.style.filter = `blur(6px)`;
                        }
                        // Keep transform consistent to prevent shifting
                        span.style.transform = `scale(1) translateY(0px)`;
                    });
                } else {
                    // Normal wave animation when not hovering
                    spans.forEach((span, index) => {
                        const distance = Math.abs(index - currentIndex);

                        // Create a sharper peak for complete clarity
                        let clarity;
                        if (distance < 1) {
                            clarity = 1; // Complete clarity at the center
                        } else {
                            clarity = Math.max(0, 1 - (distance - 1) / 5);
                        }

                        const blurAmount = 6 * (1 - clarity);

                        span.style.filter = `blur(${blurAmount}px)`;
                        span.style.transform = `scale(${1 - (1 - clarity) * 0.02}) translateY(${(1 - clarity) * 2}px)`;
                    });

                    currentIndex += 0.06;
                    if (currentIndex > spans.length + 4) {
                        currentIndex = -4;
                    }
                }

                requestAnimationFrame(animateBlur);
            }

            animateBlur();
        </script>
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js/v4513226cdae34746b4dedf0b4dfa099e1781791509496" integrity="sha512-ZE9pZaUXND66v380QUtch/5sE9tPFh2zg45pR2PB0CVkCtOREv2AJKkSidISWkysEuQ0EH8faUU5du78bx87UQ==" data-cf-beacon='{"version":"2024.11.0","token":"9ccc40d9eb844db3927596d748072f97","server_timing":{"name":{"cfCacheStatus":true,"cfEdge":true,"cfExtPri":true,"cfL4":true,"cfOrigin":true,"cfSpeedBrain":true},"location_startswith":null}}' crossorigin="anonymous"></script>
</body>
</html>
